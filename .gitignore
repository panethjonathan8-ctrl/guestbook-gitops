# Terraform — NEVER commit these
**/.terraform/
*.tfstate
*.tfstate.backup

# terraform.tfvars contains real account IDs and secrets — never commit
*.tfvars
# But do commit the example file so others know what vars are needed
!*.tfvars.example

# .terraform.lock.hcl SHOULD be committed (it locks provider versions)
# Do NOT add it here

# Helm dependency charts (generated by `helm dependency update`)
charts/*/charts/
charts/*/Chart.lock

# IDE
.idea/
.vscode/
*.swp
*.swo

# macOS
.DS_Store
